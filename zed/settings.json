  //     "language_servers": [
  //       "deno",
  //       "!typescript-language-server",
  //       "!vtsls",
  //       "!eslint"
  //     ],
  //     "formatter": "language_server"
  //   }
  // },

  // Screenshot mode - uncomment
  // "gutter": {
  //   "code_actions": false,
