{
  // Visual
  "theme": "Catppuccin Frappé",
  "icon_theme": "Catppuccin Frappé",
  "ui_font_family": "JetBrains Mono NL",
  "ui_font_size": 14,
  "buffer_font_family": "JetBrains Mono NL",
  "buffer_font_size": 14.0,
  "show_whitespaces": "boundary",
  "indent_guides": {
    "active_line_width": 2,
    "coloring": "indent_aware"
  },

  // UI
  "scrollbar": {
    "git_diff": false,
    "cursors": false
  },
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "toolbar": {
    // "breadcrumbs": false,
    // "quick_actions": false
  },
  "project_panel": {
    "auto_fold_dirs": false
  },
  "features": {
    "edit_prediction_provider": "none"
  },
  "agent": {
    "enabled": true,
    "default_model": {
      "provider": "zed.dev",
      "model": "cloude-sonnet-4"
    }
  },
  "chat_panel": {
    "button": "never"
  },
  "terminal": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "notification_panel": {
    "button": false
  },
  "outline_panel": {
    "dock": "right"
  },

  // Behavior
  "disable_ai": true,
  "tab_size": 2,
  // "preferred_line_length": 120,
  "soft_wrap": "none",
  "hover_popover_delay": 0,
  "expand_excerpt_lines": 5,
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "code_actions_on_format": {
    "source.organizeImports.biome": true,
    "source.fixAll.biome": true
  },
  "languages": {
    "Markdown": {
      "preferred_line_length": 120
    }
  },

  // Language-specific
  // "lsp": {
  //   "deno": {
  //     "settings": {
  //       "deno": {
  //         "enable": true
  //       }
  //     }
  //   }
