[user]
  name = Kamil Ogórek
  email = kamil.ogorek@gmail.com

[core]
  editor = vim
  autocrlf = input
  excludesfile = ~/.gitignore

[help]
  autocorrect = immediate

[status]
  showuntrackedfiles = all

[credential]
  helper = osxkeychain

[init]
  defaultbranch = master

[submodule]
  recurse = true

[rerere]
  enabled = true

[push]
  default = simple
  autosetupremote = true
  followtags = true

[pull]
  rebase = false

[rebase]
  autosquash = true
  updaterefs = true

[fetch]
  prune = true

[branch]
  sort = -committerdate

[tag]
  sort = version:refname

[column]
  ui = auto

#[diff]
#  noprefix = true
#  algorithm = histogram

[diff]
  external = difft

[difftool]
  prompt = false

[pager]
  difftool = true

[color]
  branch = auto
  diff = auto
  status = auto
  interactive = auto
  ui = true

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

